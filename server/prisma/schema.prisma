generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(191)
  email             String   @unique @db.VarChar(191)
  password_hash     String?
  provider          String   @default("credentials")
  oauth_id          String?
  image             String?
  is_email_verified Boolean  @default(false)

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  deleted_at        DateTime?

  customers         Customer[]
  suppliers         Supplier[]
  categories        Category[]
  products          Product[]
  warehouses        Warehouse[]
  purchases         Purchase[]
  sales             Sale[]
  invoices          Invoice[]
  recurring_invoice_templates RecurringInvoiceTemplate[]
  payments          Payment[]
  resets            PasswordResetToken[]
  business_profile  BusinessProfile?
  user_templates    UserTemplate[]
  user_saved_templates UserSavedTemplate[]

  @@map("users")
}

model BusinessProfile {
  id                   Int      @id @default(autoincrement())
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id              Int      @unique
  business_name        String   @db.VarChar(191)
  address              String?
  phone                String?
  email                String?
  website              String?
  logo_url             String?
  tax_id               String?
  currency             String   @default("INR") @db.VarChar(10)
  show_logo_on_invoice Boolean  @default(true)
  show_tax_number      Boolean  @default(true)
  show_payment_qr      Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([user_id])
  @@map("business_profiles")
}

model Template {
  id            Int               @id @default(autoincrement())
  name          String            @db.VarChar(191)
  description   String?
  layout_config Json
  created_at    DateTime          @default(now())
  sections      TemplateSection[]
  user_settings UserTemplate[]
  user_saved_templates UserSavedTemplate[]

  @@map("templates")
}

model TemplateSection {
  id            Int      @id @default(autoincrement())
  template      Template @relation(fields: [template_id], references: [id], onDelete: Cascade)
  template_id   Int
  section_key   String   @db.VarChar(120)
  section_order Int
  is_default    Boolean  @default(true)

  @@index([template_id])
  @@map("template_sections")
}

model UserTemplate {
  id              Int      @id @default(autoincrement())
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id         Int
  template        Template @relation(fields: [template_id], references: [id], onDelete: Cascade)
  template_id     Int
  enabled_sections String[]
  theme_color     String?
  section_order   String[]
  design_config   Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@unique([user_id, template_id])
  @@index([user_id])
  @@index([template_id])
  @@map("user_templates")
}

model UserSavedTemplate {
  id               Int       @id @default(autoincrement())
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id          Int
  name             String    @db.VarChar(191)
  base_template    Template? @relation(fields: [base_template_id], references: [id], onDelete: SetNull)
  base_template_id Int?
  enabled_sections String[]
  section_order    String[]
  theme_color      String?
  design_config    Json?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([user_id])
  @@index([base_template_id])
  @@map("user_saved_templates")
}

model Customer {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int

  name       String   @db.VarChar(191)
  email      String?
  phone      String?
  address    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  invoices   Invoice[]
  recurring_invoice_templates RecurringInvoiceTemplate[]
  sales      Sale[]

  @@index([user_id])
  @@map("customers")
}

model Supplier {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int

  name       String
  email      String?
  phone      String?
  address    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  purchases  Purchase[]

  @@index([user_id])
  @@map("suppliers")
}

model Category {
  id         Int      @id @default(autoincrement())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int

  name       String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products   Product[]

  @@unique([user_id, name])
  @@index([user_id])
  @@map("categories")
}

model Product {
  id            Int       @id @default(autoincrement())

  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id       Int

  category      Category? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  category_id   Int?

  name          String
  sku           String
  barcode       String?   @unique

  price         Decimal   @db.Decimal(12,2)
  cost          Decimal?  @db.Decimal(12,2)

  gst_rate      Decimal   @default(18) @db.Decimal(5,2)

  stock_on_hand Int       @default(0)
  reorder_level Int       @default(0)

  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  invoiceItems  InvoiceItem[]
  movements     StockMovement[]
  inventories   Inventory[]

  @@unique([user_id, sku])
  @@index([user_id])
  @@index([category_id])
  @@map("products")
}

model Warehouse {
  id        Int      @id @default(autoincrement())

  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id   Int

  name      String
  location  String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  inventories Inventory[]
  purchases   Purchase[]

  @@index([user_id])
  @@map("warehouses")
}

model Inventory {
  id           Int @id @default(autoincrement())

  warehouse    Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  warehouse_id Int

  product      Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id   Int

  quantity     Int @default(0)

  @@unique([warehouse_id, product_id])
  @@map("inventories")
}

model Purchase {
  id            Int       @id @default(autoincrement())

  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id       Int

  supplier      Supplier? @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  supplier_id   Int?

  warehouse     Warehouse? @relation(fields: [warehouse_id], references: [id], onDelete: SetNull)
  warehouse_id  Int?

  purchase_date DateTime  @default(now())

  subtotal      Decimal   @db.Decimal(12,2)
  tax           Decimal   @db.Decimal(12,2)
  total         Decimal   @db.Decimal(12,2)
  totalAmount   Decimal   @default(0) @db.Decimal(12,2) @map("total_amount")
  paidAmount    Decimal   @default(0) @db.Decimal(12,2) @map("paid_amount")
  pendingAmount Decimal   @default(0) @db.Decimal(12,2) @map("pending_amount")
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  paymentDate   DateTime? @map("payment_date")
  paymentMethod PaymentMethod? @map("payment_method")

  notes         String?

  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  items         PurchaseItem[]

  @@index([user_id])
  @@index([supplier_id])
  @@index([warehouse_id])
  @@map("purchases")
}

model PurchaseItem {
  id          Int      @id @default(autoincrement())

  purchase    Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  purchase_id Int

  product     Product? @relation(fields: [product_id], references: [id])
  product_id  Int?

  name        String
  quantity    Int
  unit_cost   Decimal  @db.Decimal(12,2)
  tax_rate    Decimal? @db.Decimal(5,2)
  line_total  Decimal  @db.Decimal(12,2)

  @@index([purchase_id])
  @@map("purchase_items")
}

model Sale {
  id          Int        @id @default(autoincrement())

  user        User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id     Int

  customer    Customer?  @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  customer_id Int?

  status      SaleStatus @default(COMPLETED)

  sale_date   DateTime   @default(now())

  subtotal    Decimal    @db.Decimal(12,2)
  tax         Decimal    @db.Decimal(12,2)
  total       Decimal    @db.Decimal(12,2)
  totalAmount Decimal    @default(0) @db.Decimal(12,2) @map("total_amount")
  paidAmount  Decimal    @default(0) @db.Decimal(12,2) @map("paid_amount")
  pendingAmount Decimal  @default(0) @db.Decimal(12,2) @map("pending_amount")
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  paymentDate DateTime?  @map("payment_date")
  paymentMethod PaymentMethod? @map("payment_method")

  notes       String?

  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  items       SaleItem[]

  @@index([user_id])
  @@index([customer_id])
  @@map("sales")
}

model SaleItem {
  id         Int      @id @default(autoincrement())

  sale       Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  sale_id    Int

  product    Product? @relation(fields: [product_id], references: [id])
  product_id Int?

  name       String
  quantity   Int

  unit_price Decimal  @db.Decimal(12,2)
  tax_rate   Decimal? @db.Decimal(5,2)

  line_total Decimal  @db.Decimal(12,2)

  @@index([sale_id])
  @@map("sale_items")
}

model Invoice {
  id          Int           @id @default(autoincrement())

  user        User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id     Int

  customer    Customer      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  customer_id Int

  invoice_number String     @db.VarChar(32)

  status      InvoiceStatus @default(DRAFT)

  date        DateTime      @default(now()) @map("issue_date")
  due_date    DateTime?

  subtotal    Decimal       @db.Decimal(12,2)
  tax         Decimal       @db.Decimal(12,2)
  discount    Decimal       @default(0) @db.Decimal(12,2)
  total       Decimal       @db.Decimal(12,2)

  notes       String?

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  items       InvoiceItem[]
  payments    Payment[]

  @@index([user_id])
  @@index([customer_id])
  @@index([status])
  @@index([due_date])
  @@unique([user_id, invoice_number])
  @@map("invoices")
}

model RecurringInvoiceTemplate {
  id             Int                 @id @default(autoincrement())

  user           User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id        Int

  customer       Customer            @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  customer_id    Int

  title          String              @db.VarChar(191)
  is_active      Boolean             @default(true)
  frequency      RecurrenceFrequency @default(MONTHLY)
  interval_count Int                 @default(1)

  next_run_date  DateTime
  last_run_date  DateTime?
  due_in_days    Int                 @default(7)

  discount       Decimal             @default(0) @db.Decimal(12,2)
  notes          String?
  items          Json

  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt

  @@index([user_id])
  @@index([customer_id])
  @@index([next_run_date])
  @@map("recurring_invoice_templates")
}

model InvoiceItem {
  id         Int      @id @default(autoincrement())

  invoice    Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_id Int

  product    Product? @relation(fields: [product_id], references: [id])
  product_id Int?

  name       String
  quantity   Int

  price      Decimal  @db.Decimal(12,2) @map("unit_price")
  tax_rate   Decimal? @db.Decimal(5,2)

  total      Decimal  @db.Decimal(12,2) @map("line_total")

  @@index([invoice_id])
  @@map("invoice_items")
}

model Payment {
  id         Int           @id @default(autoincrement())

  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int

  invoice    Invoice       @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_id Int

  amount     Decimal       @db.Decimal(12,2)
  method     PaymentMethod
  provider   String?       @db.VarChar(120)
  transaction_id String?   @db.VarChar(191)

  reference  String?

  paid_at    DateTime      @default(now())
  created_at DateTime      @default(now())

  @@index([invoice_id])
  @@index([user_id])
  @@map("payments")
}

model StockMovement {
  id         Int         @id @default(autoincrement())

  product    Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id Int

  change     Int
  reason     StockReason

  note       String?

  created_at DateTime    @default(now())

  @@index([product_id])
  @@map("stock_movements")
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int

  token      String   @unique
  expires_at DateTime
  used_at    DateTime?

  created_at DateTime @default(now())

  @@index([user_id])
  @@map("password_reset_tokens")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  UPI
  CHEQUE
  OTHER
}

enum PaymentStatus {
  PAID
  PARTIALLY_PAID
  UNPAID
}

enum StockReason {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
  DAMAGE
}

enum SaleStatus {
  DRAFT
  COMPLETED
  VOID
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}